    "react": "^18.0.0",
    "react-data-table-component": "^7.6.2",
    "react-dom": "^18.0.0",
    "react-helmet-async": "^2.0.4",
    "react-redux": "^9.0.0",
    "react-router-dom": "^6.0.0",
