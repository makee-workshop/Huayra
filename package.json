    "bootstrap": "^5.3.0",
    "classnames": "^2.2.5",
    "compression": "1.x.x",
    "cors": "^2.8.5",
    "debug": "^2.6.9",
    "emailjs": "3.7.0",
    "express": "^5.0.0",
    "helmet": "2.x.x",
    "jsonwebtoken": "^8.5.1",
    "method-override": "2.3.10",
    "mongoose": "8.9.3",
    "morgan": ">=1.10.0",
    "ms": "^2.1.2",
